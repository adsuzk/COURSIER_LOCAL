# Configuration .htaccess optimisée pour LWS - Suzosky Coursier
# Version spéciale pour résoudre les problèmes d'affichage

RewriteEngine On

# 🎯 GESTION DE L'INDEX - PRIORITÉ STATIQUE
DirectoryIndex index.html index.php

# 🔧 FORÇAGE DU TYPE DE CONTENU POUR HTML
<FilesMatch "\.(html|htm)$">
    ForceType text/html
    Header set Content-Type "text/html; charset=UTF-8"
</FilesMatch>

# 🔧 CONFIGURATION PHP POUR LWS
<FilesMatch "\.(php)$">
    Header set Content-Type "text/html; charset=UTF-8"
</FilesMatch>

# 🎯 REDIRECTIONS PRINCIPALES - SUZOSKY 2025
# /admin → admin.php
RewriteRule ^admin/?$ admin.php [L]

# /business → business.php (changé de .html vers .php pour plus de flexibilité)
RewriteRule ^business/?$ business.php [L]

# /coursier → coursier.php
RewriteRule ^coursier/?$ coursier.php [L]

# /test → test_lws.php (page de test rapide)
RewriteRule ^test/?$ test_lws.php [L]

# /diagnostic → diagnostic_lws.php
RewriteRule ^diagnostic/?$ diagnostic_lws.php [L]

# /init → init_lws_database.php
RewriteRule ^init/?$ init_lws_database.php [L]

# 📱 REDIRECTIONS PAGES STATIQUES
RewriteRule ^recrutement/?$ recrutement.php [L]
RewriteRule ^cgu/?$ cgu.html [L]
RewriteRule ^app/?$ app.php [L]
RewriteRule ^apk/?$ apk.php [L]

# 🔒 PROTECTION FICHIERS SENSIBLES
<Files "*.sql">
    Order allow,deny
    Deny from all
</Files>

<Files "*.log">
    Order allow,deny
    Deny from all
</Files>

# Protection des fichiers de configuration sauf les principaux
<FilesMatch "^config_(?!db\.php$|lws_production\.php$).*\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protection des fichiers de backup
<FilesMatch "^.*\.(bak|backup|old|orig|save)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# 🌐 GESTION DES ERREURS LWS
ErrorDocument 404 /index.html
ErrorDocument 403 /index.html
ErrorDocument 500 /test_lws.php

# 📦 CACHE ET COMPRESSION OPTIMISÉS POUR LWS
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType application/json "access plus 1 hour"
</IfModule>

# Compression GZIP pour LWS
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
</IfModule>

# 🔐 HEADERS DE SÉCURITÉ ADAPTÉS LWS
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options SAMEORIGIN
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # CORS pour les APIs
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
</IfModule>

# 📄 GESTION SPÉCIALE DES TYPES MIME POUR LWS
AddType text/html .html .htm
AddType application/json .json
AddType text/css .css
AddType application/javascript .js

# 🚀 OPTIMISATIONS SERVEUR POUR LWS
<IfModule mod_setenvif.c>
    SetEnvIfNoCase Request_URI \.(gif|jpe?g|png|svg|css|js|woff|woff2|ttf|eot)$ no-gzip dont-vary
</IfModule>

# 📱 SUPPORT PWA ET MANIFEST
<FilesMatch "\.(webmanifest|manifest\.json)$">
    Header set Content-Type "application/manifest+json"
    Header set Cache-Control "public, max-age=604800"
</FilesMatch>

# 🔧 REDIRECTION HTTPS (si disponible sur LWS)
# Décommentez si vous avez activé HTTPS sur LWS
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
